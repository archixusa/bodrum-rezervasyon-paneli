# =========================================
# Supabase
# =========================================
# supabase.com'da yeni proje açtıktan sonra Settings > API'den alın.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY                 # form'lar ve panel client tarafı için (public OK)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY  # Edge Function ve admin server tarafı — ASLA client'a sızdırma

# Public variants (Next.js client bundle'ında okumak için)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# =========================================
# Telegram Bot
# =========================================
# 1) Telegram'da @BotFather'a yaz -> /newbot -> token al
# 2) Bot ile mesajlaş, sonra https://api.telegram.org/bot<token>/getUpdates -> chat.id'yi kopyala
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================================
# Resend (Email bildirimleri)
# =========================================
# resend.com -> API Keys -> Create. Domain doğrulanmadıysa onboarding@resend.dev kullan.
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=info@bodrumapartkiralama.com

# =========================================
# Admin panel
# =========================================
NEXT_PUBLIC_PANEL_URL=http://localhost:3000

# =========================================
# Optional: spam koruması
# =========================================
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET=
